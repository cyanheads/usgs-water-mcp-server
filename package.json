{
  "name": "@cyanheads/usgs-water-mcp-server",
  "version": "0.1.8",
  "description": "Query real-time and historical water data from ~8,000 USGS stream gages and groundwater wells via MCP. STDIO or Streamable HTTP.",
  "mcpName": "io.github.cyanheads/usgs-water-mcp-server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "usgs-water-mcp-server": "dist/index.js"
  },
  "files": [
    "changelog/",
    "dist/",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    "AGENTS.md",
    "Dockerfile",
    "server.json"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "rebuild": "bun run scripts/clean.ts && bun run scripts/build.ts",
    "clean": "bun run scripts/clean.ts",
    "devcheck": "bun run scripts/devcheck.ts",
    "audit:refresh": "rm -f bun.lock && bun install && bun audit",
    "tree": "bun run scripts/tree.ts",
    "list-skills": "bun run scripts/list-skills.ts",
    "format": "biome check --write .",
    "format:unsafe": "biome check --write --unsafe .",
    "lint:mcp": "bun run scripts/lint-mcp.ts",
    "lint:packaging": "bun run scripts/lint-packaging.ts",
    "bundle": "bun run build && npx -y @anthropic-ai/mcpb pack . dist/usgs-water-mcp-server.mcpb && bun run scripts/clean-mcpb.ts dist/usgs-water-mcp-server.mcpb",
    "changelog:build": "bun run scripts/build-changelog.ts",
    "changelog:check": "bun run scripts/build-changelog.ts --check",
    "release:github": "bun run scripts/release-github.ts",
    "publish-mcp": "mcp-publisher login github -token \"$(security find-generic-password -a \"$USER\" -s mcp-publisher-github-pat -w)\" && mcp-publisher publish",
    "test": "vitest run",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "typescript",
    "bun",
    "stdio",
    "streamable-http",
    "ai-agent",
    "usgs",
    "water-data",
    "hydrology",
    "nwis",
    "stream-gage",
    "groundwater",
    "streamflow",
    "water-quality",
    "real-time-data",
    "environmental-data"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/usgs-water-mcp-server.git"
  },
  "homepage": "https://github.com/cyanheads/usgs-water-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/usgs-water-mcp-server/issues"
  },
  "author": "Casey Hand <casey@caseyjhand.com> (https://caseyjhand.com)",
  "license": "Apache-2.0",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cyanheads"
    },
    {
      "type": "buy_me_a_coffee",
      "url": "https://www.buymeacoffee.com/cyanheads"
    }
  ],
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  },
  "trustedDependencies": ["@socketsecurity/bun-security-scanner"],
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.10.14",
    "@duckdb/node-api": "^1.5.4-r.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/node": "^26.1.1",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.6",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
